---
import { readFileSync } from 'node:fs';
import { nushuMarkupToHtml, stripNushuMarkup } from '@/lib/nushu-markup';

interface SubtitleSegment {
  chars: string;
  note: string;
}

interface Props {
  title: string;
  chapterLabel?: string;
  subtitle?: string;
  subtitleSegments?: SubtitleSegment[];
  coverImage?: string;
}

const { title, chapterLabel, subtitle, subtitleSegments, coverImage } = Astro.props;

// For SVG coverImages, read inline for CSS theme control
let inlineSvg: string | null = null;
if (coverImage?.endsWith('.svg')) {
  try {
    inlineSvg = readFileSync(`public${coverImage}`, 'utf-8');
  } catch { /* fallback to <img> */ }
}
---

<header class="chapter-header">
  {chapterLabel && (
    <div class="chapter-label" set:html={nushuMarkupToHtml(chapterLabel)} />
  )}

  <h1 class="chapter-title" set:html={nushuMarkupToHtml(title)} />

  {subtitle && !subtitleSegments && (
    <div class="chapter-subtitle">{subtitle}</div>
  )}

  {subtitleSegments && subtitleSegments.length > 0 && (
    <div class="chapter-subtitle">
      <span class="subtitle-segments">
        {subtitleSegments.map((seg, i) => (
          <>
            {i > 0 && <span class="subtitle-segment-spacer" />}
            <span class="subtitle-segment">
              {seg.chars}
              <span class="subtitle-segment-tooltip">{seg.note}</span>
            </span>
          </>
        ))}
      </span>
    </div>
  )}

  {inlineSvg ? (
    <div class="chapter-illustration" set:html={inlineSvg} />
  ) : coverImage ? (
    <img src={coverImage} alt={stripNushuMarkup(title)} class="chapter-cover" loading="lazy" />
  ) : null}

  <hr class="chapter-divider" />
</header>
