node_modules/
dist/
.astro/
.DS_Store
*.log
.env
.env.*

# Build-time generated font subsets (created by subset-fonts.py on server)
public/fonts/SiteSerif-*.woff2
!public/fonts/NushuSerif.woff2

# Content and images come from the private content repo at deploy time.
# Do not commit them to the public framework repo.
src/content/novel/
!src/content/novel/.gitkeep
public/images/
!public/images/.gitkeep

# Branding assets (from content repo branding/ directory)
public/favicon.svg
public/logo.svg
public/apple-touch-icon.png
public/icon-192.png
public/icon-512.png
public/og-image.png
public/site.webmanifest
